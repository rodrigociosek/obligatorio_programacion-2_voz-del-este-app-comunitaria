<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VozDelEsteMaui3.Vistas.Peliculas"
             Title=""
             x:Name="PaginaPeliculas">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Título -->
            <Label Text="🎬 Películas"
                   FontSize="36"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />

            <!-- Buscador -->
            <Grid RowDefinitions="auto"
                  ColumnDefinitions="*,auto"
                  ColumnSpacing="20"
                  HorizontalOptions="Fill"
                  MaximumWidthRequest="800">
                <Entry Grid.Column="0"
                       x:Name="BuscadorEntry"
                       Placeholder="Buscar películas..."
                       Text="{Binding Palabraclave}"
                       HorizontalOptions="Fill" />
                <Button Grid.Column="1"
                        HorizontalOptions="Start"
                        Text="Buscar"
                        Command="{Binding BuscarCommand}" />
            </Grid>

            <Grid ColumnDefinitions="150,*"
                  RowDefinitions="Auto"
                  ColumnSpacing="20"
                  Margin="0,10,0,0">

                <ScrollView Grid.Column="0">
                    <VerticalStackLayout Padding="10" Spacing="12">
                        <Label Text="🎭 Géneros"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{StaticResource ColorPrimario}" />

                        <CollectionView ItemsSource="{Binding Generos}"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="4" ColumnDefinitions="Auto,auto">
                                        <CheckBox IsChecked="{Binding EstaSeleccionado, Mode=TwoWay}"
                                                  VerticalOptions="Center"
                                                  Color="{StaticResource ColorPrimario}" />
                                        <Label Grid.Column="1" 
                                            Text="{Binding Genero}" 
                                               FontSize="14"
                                               VerticalOptions="Center"
                                               Margin="0,0,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </ScrollView>

                <ScrollView Grid.Column="1">
                    <FlexLayout BindableLayout.ItemsSource="{Binding Peliculas}"
                                Direction="Row"
                                Wrap="Wrap"
                                JustifyContent="Center"
                                AlignItems="Center"
                                Margin="10"
                                AlignContent="Start">

                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="{StaticResource BlancoSuave}"
                                        StrokeThickness="0.5"
                                        BackgroundColor="{StaticResource NegroSuave}"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="0"
                                        Margin="10"
                                        WidthRequest="180"
                                        HeightRequest="300">

                                    <Grid RowDefinitions="auto,auto,auto,*"
                                          ColumnDefinitions="*">

                                        <!-- Imagen -->
                                        <Image Grid.Row="0"
                                               Source="{Binding ImagenUrl}"
                                               Aspect="AspectFill"
                                               HeightRequest="180"
                                               WidthRequest="180"
                                               Clip="RoundRectangle 12" />

                                        <!-- Título -->
                                        <Label Grid.Row="1"
                                               Text="{Binding Titulo}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               LineBreakMode="TailTruncation"
                                               Margin="8,4,8,0"
                                               HorizontalTextAlignment="Center"
                                               TextColor="White" />

                                        <!-- Año y valoracion -->
                                        <HorizontalStackLayout Grid.Row="2"
                                                               Spacing="6"
                                                               Margin="8,2,8,0"
                                                               HorizontalOptions="Center">
                                            <Label Text="{Binding FechaEstreno, StringFormat='{0:yyyy}'}"
                                                   FontSize="13"
                                                   TextColor="{StaticResource BlancoSuave}" />
                                            <Label Text="★"
                                                   FontSize="13"
                                                   TextColor="Orange" />
                                            <Label Text="{Binding Valoracion}"
                                                   FontSize="13"
                                                   TextColor="Orange" />
                                        </HorizontalStackLayout>

                                        <!-- Boton Ver mas -->
                                        <Button Grid.Row="3"
                                                Text="Ver más"
                                                Command="{Binding BindingContext.VerPeliculaCommand, Source={x:Reference PaginaPeliculas}}"
                                                CommandParameter="{Binding .}"
                                                Margin="8,4,8,8"
                                                HorizontalOptions="Center"
                                                VerticalOptions="End"
                                                BackgroundColor="{StaticResource ColorPrimarioOscuro}"
                                                TextColor="White"
                                                CornerRadius="8"
                                                WidthRequest="120" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </ScrollView>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>