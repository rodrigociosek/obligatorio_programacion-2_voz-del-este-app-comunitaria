<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VozDelEsteMaui3.ViewModels"
             x:Class="VozDelEsteMaui3.Vistas.Modales.InformacionUsuarioModal"
             x:DataType="vm:MainPageViewModel"
             Title="InformacionUsuarioModal"
             BackgroundColor="#80000000"
             NavigationPage.HasNavigationBar="False">

    <Border
         WidthRequest="300"
         HeightRequest="600"
            HorizontalOptions="Center"
        VerticalOptions="Fill"
        Padding="20"
        StrokeShape="RoundRectangle 12">
        <Grid RowDefinitions="auto,*,auto">
            <Border Grid.Row="0"
                StrokeShape="RoundRectangle 100" HorizontalOptions="Center" HeightRequest="120" WidthRequest="120" VerticalOptions="Start">
                
                <Image Source="{Binding UsuarioActual.FotoUrl}" Aspect="AspectFill"/>
            </Border>
            <Grid RowDefinitions="auto,auto,auto,auto,auto"
                Grid.Row="1" VerticalOptions="Center" RowSpacing="25">

                <StackLayout Grid.Row="0">
         <Label Text="Alias" FontAttributes="Bold" />
         <Label Text="{Binding UsuarioActual.Alias}" />
                </StackLayout>
                    
                <StackLayout Grid.Row="1">
         <Label Text="Nombre completo" FontAttributes="Bold"/>
         <Label Text="{Binding UsuarioActual.NombreCompleto}" />
                </StackLayout>

                <StackLayout Grid.Row="2">
         <Label Text="Dirección" FontAttributes="Bold"/>
         <Label Text="{Binding UsuarioActual.Direccion}" />
                </StackLayout>
                
                <StackLayout Grid.Row="3">
                <Label Text="Teléfono" FontAttributes="Bold"/>
         <Label Text="{Binding UsuarioActual.Telefono}" />
                </StackLayout>

                <StackLayout Grid.Row="4">
         <Label Text="Email" FontAttributes="Bold"/>
         <Label Text="{Binding UsuarioActual.Email}" />
                </StackLayout>
            </Grid>

            <Button Grid.Row="2" VerticalOptions="End"  
                Text="Cerrar" Command="{Binding CerrarModalCommand}" />

      </Grid>
      </Border>

</ContentPage>